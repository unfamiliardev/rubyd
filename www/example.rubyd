<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>rubyd template demo</title>
  <style>
    body { font-family: Segoe UI, sans-serif; margin: 2rem; line-height: 1.5; }
    code { background: #f0f0f0; padding: 0.1rem 0.35rem; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>rubyd Template Demo</h1>
  <p>This page is rendered from <code>.rubyd</code> source with placeholder expansion.</p>
  <ul>
    <li>Method: <strong>{{method}}</strong></li>
    <li>Path: <strong>{{path}}</strong></li>
    <li>Query: <strong>{{query}}</strong></li>
    <li>Client IP: <strong>{{remote_addr}}</strong></li>
    <li>Server UTC time: <strong>{{time}}</strong></li>
  </ul>
</body>
</html>
